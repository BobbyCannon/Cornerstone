<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFrameworks>netstandard2.0;net9.0;net9.0-android;net9.0-windows10.0.19041.0</TargetFrameworks>
		<UseWpf Condition="'$(TargetFramework)' == 'net9.0-windows10.0.19041.0'">true</UseWpf>
		<AssemblyTitle>Cornerstone</AssemblyTitle>
		<PackageId>Cornerstone</PackageId>
		<GenerateDocumentationFile>false</GenerateDocumentationFile>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<SignAssembly>true</SignAssembly>
	</PropertyGroup>
	<ItemGroup>
		<Compile Remove="Android\**" />
		<None Include="Android\**" />
		<Compile Remove="Windows\**" />
		<None Include="Windows\**" />
	</ItemGroup>
	<ItemGroup>
		<EmbeddedResource Include="Resources\City.txt" />
		<EmbeddedResource Include="Resources\Animals.txt" />
		<EmbeddedResource Include="Resources\FirstNames.txt" />
		<EmbeddedResource Include="Resources\LastNames.txt" />
		<EmbeddedResource Include="Resources\States.txt" />
		<EmbeddedResource Include="Resources\Streets.txt" />
		<EmbeddedResource Include="Resources\Colors.txt" />
		<EmbeddedResource Include="Resources\StreetTypes.txt" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.0" />
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp.Features" Version="4.12.0" />
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.12.0" />
		<PackageReference Include="Microsoft.CodeAnalysis.Workspaces.Common" Version="4.12.0" />
		<PackageReference Include="Microsoft.Extensions.Caching.Memory" Version="9.0.0" />
		<PackageReference Include="System.Management" Version="9.0.0" />
		<PackageReference Include="System.Security.Cryptography.ProtectedData" Version="9.0.0" />
		<PackageReference Include="System.Text.Json" Version="9.0.0" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
		<PackageReference Include="Microsoft.CSharp" Version="4.7.0" />
		<PackageReference Include="Microsoft.Win32.Registry" Version="5.0.0" />
		<PackageReference Include="System.ComponentModel.Annotations" Version="5.0.0" />
		<PackageReference Include="System.Security.Principal.Windows" Version="5.0.0" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net9.0-android'">
		<Compile Include="Android\**\*.cs" />
		<PackageReference Include="Microsoft.Maui.Essentials" Version="9.0.21" />
		<PackageReference Include="Xamarin.AndroidX.AppCompat" Version="1.7.0.4" />
		<PackageReference Include="Xamarin.GooglePlayServices.Location" Version="121.3.0.3" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net9.0-windows10.0.19041.0'">
		<Compile Include="Windows\**\*.cs" />
	</ItemGroup>
	<ItemGroup>
		<InternalsVisibleTo Include="Cornerstone.Automation" Key="" />
		<InternalsVisibleTo Include="Cornerstone.Avalonia" Key="" />
		<InternalsVisibleTo Include="Cornerstone.EntityFramework" Key="" />
		<InternalsVisibleTo Include="Cornerstone.Newtonsoft" Key="" />
		<InternalsVisibleTo Include="Cornerstone.PerformanceTests" Key="" />
		<InternalsVisibleTo Include="Cornerstone.PowerShell" Key="" />
		<InternalsVisibleTo Include="Cornerstone.UnitTests" Key="" />
		<InternalsVisibleTo Include="Cornerstone.Web" Key="" />
	</ItemGroup>
</Project>