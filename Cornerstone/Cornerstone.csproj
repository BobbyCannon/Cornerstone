<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFrameworks>net9.0;net9.0-android;net9.0-ios;net9.0-browser;net9.0-windows10.0.19041.0</TargetFrameworks>
		<UseWpf Condition="'$(TargetFramework)' == 'net9.0-windows10.0.19041.0'">true</UseWpf>
		<AssemblyTitle>Cornerstone</AssemblyTitle>
		<PackageId>Cornerstone</PackageId>
		<GenerateDocumentationFile>false</GenerateDocumentationFile>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<SignAssembly>true</SignAssembly>
	</PropertyGroup>
	<ItemGroup>
		<Compile Remove="Platforms\Android\**" />
		<None Include="Platforms\Android\**" />
		<Compile Remove="Platforms\Browser\**" />
		<None Include="Platforms\Browser\**" />
		<Compile Remove="Platforms\iOS\**" />
		<None Include="Platforms\iOS\**" />
		<Compile Remove="Platforms\Windows\**" />
		<None Include="Platforms\Windows\**" />
	</ItemGroup>
	<ItemGroup>
		<EmbeddedResource Include="Resources\**" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.0" />
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp.Features" Version="4.12.0" />
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.12.0" />
		<PackageReference Include="Microsoft.CodeAnalysis.Workspaces.Common" Version="4.12.0" />
		<PackageReference Include="Microsoft.Extensions.Caching.Memory" Version="9.0.2" />
		<PackageReference Include="System.Management" Version="9.0.2" />
		<PackageReference Include="System.Security.Cryptography.ProtectedData" Version="9.0.2" />
		<PackageReference Include="System.Text.Json" Version="9.0.2" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net9.0-android'">
		<Compile Include="Platforms\Android\**\*.cs" />
		<PackageReference Include="Microsoft.Maui.Essentials" Version="9.0.40" />
		<PackageReference Include="Xamarin.AndroidX.AppCompat" Version="1.7.0.5" />
		<PackageReference Include="Xamarin.GooglePlayServices.Location" Version="121.3.0.4" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net9.0-browser'">
		<Compile Include="Platforms\Browser\**\*.cs" />
		<PackageReference Include="Avalonia.Browser" Version="$(AvaloniaVersion)" />
		<PackageReference Include="Microsoft.JSInterop" Version="9.0.2" />
		<PackageReference Include="Microsoft.AspNetCore.Components" Version="9.0.2" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net9.0-ios'">
		<Compile Include="Platforms\iOS\**\*.cs" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net9.0-windows10.0.19041.0'">
		<Compile Include="Platforms\Windows\**\*.cs" />
	</ItemGroup>
	<ItemGroup>
		<InternalsVisibleTo Include="Cornerstone.Automation" Key="" />
		<InternalsVisibleTo Include="Cornerstone.Avalonia" Key="" />
		<InternalsVisibleTo Include="Cornerstone.EntityFramework" Key="" />
		<InternalsVisibleTo Include="Cornerstone.Newtonsoft" Key="" />
		<InternalsVisibleTo Include="Cornerstone.PerformanceTests" Key="" />
		<InternalsVisibleTo Include="Cornerstone.PowerShell" Key="" />
		<InternalsVisibleTo Include="Cornerstone.UnitTests" Key="" />
		<InternalsVisibleTo Include="Cornerstone.IntegrationTests" Key="" />
		<InternalsVisibleTo Include="Cornerstone.Web" Key="" />
	</ItemGroup>
</Project>