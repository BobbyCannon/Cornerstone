<UserControl
		xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:tabs="clr-namespace:Cornerstone.Sample.Tabs"
		mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="600"
		x:Class="Cornerstone.Sample.Tabs.TabDockingManager"
		x:DataType="tabs:TabDockingManager">
	<!-- ReSharper disable Xaml.MissingGridIndex -->
	<DockPanel>
		<Grid DockPanel.Dock="Top" Margin="10">
			<TextBlock Classes="Header"
					HorizontalAlignment="Center"
					Text="Docking Manager" />
		</Grid>
		<DockingManager x:Name="DockingManager"
				Margin="0,20,0,0" />
	</DockPanel>
</UserControl>