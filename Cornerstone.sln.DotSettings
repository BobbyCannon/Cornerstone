	<s:Int64 x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=B9383001B58E7F4399544EC6C6D4D82F/Field/=name/Order/@EntryValue">0</s:Int64>
	<s:Boolean x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=B9383001B58E7F4399544EC6C6D4D82F/Field/=newException/@KeyIndexDefined">False</s:Boolean>
	<s:String x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=B9383001B58E7F4399544EC6C6D4D82F/Text/@EntryValue">/// &lt;summary&gt;&#xD;
/// Represents an $name$ exception.&#xD;
/// &lt;/summary&gt;&#xD;
[Serializable]&#xD;
[ExcludeFromCodeCoverage]&#xD;
public class $name$Exception : CornerstoneException&#xD;
{&#xD;
	#region Constructors&#xD;
&#xD;
	/// &lt;summary&gt;&#xD;
	/// Initializes an instance of the $name$ exception.&#xD;
	/// &lt;/summary&gt;&#xD;
	public $name$Exception()&#xD;
	{&#xD;
	}&#xD;
&#xD;
	/// &lt;summary&gt;&#xD;
	/// Initializes an instance of the $name$ exception.&#xD;
	/// &lt;/summary&gt;&#xD;
	public $name$Exception(string message) : base(message)&#xD;
	{&#xD;
	}&#xD;
&#xD;
	/// &lt;summary&gt;&#xD;
	/// Initializes an instance of the $name$ exception.&#xD;
	/// &lt;/summary&gt;&#xD;
	public $name$Exception(string message, Exception inner) : base(message, inner)&#xD;
	{&#xD;
	}&#xD;
&#xD;
	/// &lt;summary&gt;&#xD;
	/// Initializes an instance of the $name$ exception.&#xD;
	/// &lt;/summary&gt;&#xD;
	protected $name$Exception(SerializationInfo info, StreamingContext context) : base(info, context)&#xD;
	{&#xD;
	}&#xD;
&#xD;
	#endregion&#xD;
}</s:String>
