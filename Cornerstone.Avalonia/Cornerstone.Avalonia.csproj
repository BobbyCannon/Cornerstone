<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFrameworks>net10.0;net10.0-android;net10.0-browser;net10.0-ios;net10.0-windows10.0.26100.0;</TargetFrameworks>
		<SupportedOSPlatformVersion Condition="'$(TargetFramework)' == 'net10.0-android'">35</SupportedOSPlatformVersion>
		<AssemblyTitle>Cornerstone.Avalonia</AssemblyTitle>
		<PackageId>Cornerstone.Avalonia</PackageId>
		<SignAssembly>true</SignAssembly>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>
	<ItemGroup>
		<Compile Remove="Platforms\**" />
		<None Include="Platforms\**" />
		<Compile Include="Platforms\*.cs" />
	</ItemGroup>
	<ItemGroup>
		<EmbeddedResource Include="**\*.xshd;**\*.resx;" Exclude="bin\**;obj\**;**\*.xproj;packages\**;@(EmbeddedResource)" />
		<AvaloniaResource Include="**\*.xaml;Assets\*;" Exclude="bin\**;obj\**;**\*.xproj;packages\**;@(EmbeddedResource)" />
		<AvaloniaResource Include="Assets\**" />
	</ItemGroup>
	<ItemGroup>
		<None Remove="Resources\RightArrow.cur" />
		<AvaloniaResource Include="Resources\RightArrow.cur" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="Avalonia" Version="$(AvaloniaVersion)" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\Cornerstone\Cornerstone.csproj" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0-android'">
		<Compile Include="Platforms\Android\**\*.cs" />
		<PackageReference Include="Avalonia.Android" Version="$(AvaloniaVersion)" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0-browser'">
		<Compile Include="Platforms\Browser\**\*.cs" />
		<PackageReference Include="Avalonia.Browser" Version="$(AvaloniaVersion)" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0-ios'">
		<Compile Include="Platforms\iOS\**\*.cs" />
		<PackageReference Include="Avalonia.iOS" Version="$(AvaloniaVersion)" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0-windows10.0.26100.0'">
		<Compile Include="Platforms\Windows\**\*.cs" />
	</ItemGroup>
	<ItemGroup>
		<InternalsVisibleTo Include="Cornerstone.AutomationTests" Key="" />
		<InternalsVisibleTo Include="Cornerstone.IntegrationTests" Key="" />
		<InternalsVisibleTo Include="Cornerstone.UnitTests" Key="" />
	</ItemGroup>
</Project>