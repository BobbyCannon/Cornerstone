<ResourceDictionary
		xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:ClassModifier="internal">
	<ControlTheme x:Key="{x:Type EmbeddableControlRoot}" TargetType="EmbeddableControlRoot">
		<Setter Property="Foreground" Value="{DynamicResource Foreground00}" />
		<Setter Property="Background" Value="{DynamicResource Background02}" />
		<Setter Property="TopLevel.SystemBarColor" Value="{DynamicResource TitleBarBackground}" />
		<Setter Property="FontSize" Value="{DynamicResource ControlFontSize}" />
		<Setter Property="FontFamily" Value="{DynamicResource OpenSansRegular}" />
		<Setter Property="Template">
			<ControlTemplate>
				<Panel>
					<Border
							Name="PART_TransparencyFallback"
							IsHitTestVisible="False" />
					<Border Background="{TemplateBinding Background}">
						<VisualLayerManager>
							<ContentPresenter
									Name="PART_ContentPresenter"
									ContentTemplate="{TemplateBinding ContentTemplate}"
									Content="{TemplateBinding Content}"
									Margin="{TemplateBinding Padding}" />
						</VisualLayerManager>
					</Border>
				</Panel>
			</ControlTemplate>
		</Setter>
	</ControlTheme>
</ResourceDictionary>