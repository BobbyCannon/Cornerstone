<ResourceDictionary
		xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<ControlTheme x:Key="{x:Type CheckBox}" TargetType="CheckBox">
		<Setter Property="Theme.Color" Value="Current" />
		<Setter Property="Foreground" Value="{DynamicResource Foreground00}" />
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="BorderBrush" Value="Transparent" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="Padding" Value="8,0,0,0" />
		<Setter Property="MinHeight" Value="32" />
		<Setter Property="FontFamily" Value="{x:Static CornerstoneTheme.DejaVuSansMono}" />
		<Setter Property="FontSize" Value="{DynamicResource ControlFontSize}" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="CornerRadius" Value="4" />
		<Setter Property="Template">
			<ControlTemplate>
				<Grid x:Name="RootGrid"
						ColumnDefinitions="22,*"
						Height="{TemplateBinding Height}"
						MinHeight="{TemplateBinding Height}">
					<Border
							Grid.Column="0"
							Grid.ColumnSpan="2"
							x:Name="PART_Border"
							Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="{TemplateBinding CornerRadius}" />
					<Grid Grid.Column="0"
							VerticalAlignment="Center">
						<Border x:Name="NormalRectangle"
								Background="{DynamicResource Background05}"
								BorderThickness="2"
								BorderBrush="{DynamicResource Background09}"
								CornerRadius="{TemplateBinding CornerRadius}"
								UseLayoutRounding="False"
								Height="22"
								Width="22"
								VerticalAlignment="Center" />
						<Viewbox UseLayoutRounding="False">
							<Panel>
								<Panel Height="16" Width="16" />
								<Path x:Name="CheckGlyph"
										Opacity="0"
										StrokeThickness="1.5"
										Stroke="{DynamicResource Foreground00}"
										Stretch="Uniform"
										Width="8"
										Height="8"
										Margin="0,1,0,0"
										VerticalAlignment="Center"
										FlowDirection="LeftToRight" />
								<Border
										x:Name="IndeterminateGlyph"
										Opacity="0"
										Background="{DynamicResource Foreground00}"
										CornerRadius="2"
										Width="8"
										Height="8"
										VerticalAlignment="Center"
										HorizontalAlignment="Center" />
							</Panel>
						</Viewbox>
					</Grid>
					<ContentPresenter
							Grid.Column="1"
							x:Name="ContentPresenter"
							ContentTemplate="{TemplateBinding ContentTemplate}"
							Content="{TemplateBinding Content}"
							Margin="{TemplateBinding Padding}"
							RecognizesAccessKey="True"
							HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
							VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
							TextWrapping="Wrap">
						<ContentPresenter.Styles>
							<Style Selector="ContentPresenter:empty">
								<Setter Property="IsVisible" Value="False" />
							</Style>
						</ContentPresenter.Styles>
					</ContentPresenter>
				</Grid>
			</ControlTemplate>
		</Setter>
		<Style Selector="^:pressed">
			<Style Selector="^ /template/ Border#NormalRectangle">
				<Setter Property="Background" Value="{DynamicResource Background05}" />
			</Style>
		</Style>
		<Style Selector="^:disabled">
			<Style Selector="^ /template/ ContentPresenter#ContentPresenter">
				<Setter Property="Foreground" Value="{DynamicResource Foreground04}" />
			</Style>
			<Style Selector="^ /template/ Border#NormalRectangle">
				<Setter Property="Background" Value="{DynamicResource Background04}" />
			</Style>
		</Style>
		<Style Selector="^:checked">
			<Style Selector="^ /template/ Border#NormalRectangle">
				<Setter Property="Background" Value="{DynamicResource Background05}" />
				<Setter Property="BorderBrush" Value="{DynamicResource Background05}" />
			</Style>
			<Style Selector="^ /template/ Path#CheckGlyph">
				<Setter Property="Data" Value="M1507 31L438 1101L-119 543L-29 453L438 919L1417 -59L1507 31Z" />
				<Setter Property="Width" Value="9" />
				<Setter Property="Opacity" Value="1" />
			</Style>
			<Style Selector="^:disabled">
				<Style Selector="^ ContentPresenter#ContentPresenter">
					<Setter Property="Foreground" Value="{DynamicResource Foreground04}" />
				</Style>
				<Style Selector="^ /template/ Border#NormalRectangle">
					<Setter Property="Background" Value="{DynamicResource Background04}" />
				</Style>
				<Style Selector="^ /template/ Path#CheckGlyph">
					<Setter Property="Fill" Value="{DynamicResource Foreground04}" />
				</Style>
			</Style>
		</Style>
		<Style Selector="^:indeterminate">
			<Style Selector="^ /template/ Border#NormalRectangle">
				<Setter Property="Background" Value="{DynamicResource Background06}" />
				<Setter Property="BorderBrush" Value="{DynamicResource Background06}" />
			</Style>
			<Style Selector="^ /template/ Border#IndeterminateGlyph">
				<Setter Property="Opacity" Value="1" />
			</Style>
			<Style Selector="^:disabled">
				<Style Selector="^ /template/ ContentPresenter#ContentPresenter">
					<Setter Property="Foreground" Value="{DynamicResource Foreground04}" />
				</Style>
				<Style Selector="^ /template/ Border#NormalRectangle">
					<Setter Property="Background" Value="{DynamicResource Background04}" />
					<Setter Property="BorderBrush" Value="{DynamicResource Background06}" />
				</Style>
				<Style Selector="^ /template/ Border#IndeterminateGlyph">
					<Setter Property="Background" Value="{DynamicResource Foreground04}" />
				</Style>
			</Style>
		</Style>

		<!-- Code Template - Color -->
		<Style Selector="^[(Theme.Color)=Current]">
			<Style Selector="^:checked,^:indeterminate">
				<Style Selector="^ /template/ Border#NormalRectangle">
					<Setter Property="Background" Value="{DynamicResource ThemeColor05}" />
					<Setter Property="BorderBrush" Value="{DynamicResource ThemeColor05}" />
				</Style>
				<Style Selector="^ /template/ Path#CheckGlyph">
					<Setter Property="Stroke" Value="{DynamicResource ThemeText05}" />
				</Style>
				<Style Selector="^ /template/ Border#IndeterminateGlyph">
					<Setter Property="Background" Value="{DynamicResource ThemeText05}" />
				</Style>
				<Style Selector="^:disabled">
					<Style Selector="^ /template/ Border#NormalRectangle">
						<Setter Property="Background" Value="{DynamicResource ThemeColor03}" />
						<Setter Property="BorderBrush" Value="{DynamicResource ThemeColor03}" />
					</Style>
					<Style Selector="^ /template/ Path#CheckGlyph">
						<Setter Property="Stroke" Value="{DynamicResource ThemeColor09}" />
					</Style>
					<Style Selector="^ /template/ Border#IndeterminateGlyph">
						<Setter Property="Background" Value="{DynamicResource ThemeColor09}" />
						<Setter Property="BorderBrush" Value="{DynamicResource ThemeColor09}" />
					</Style>
				</Style>
			</Style>
		</Style>
		<!-- Code Template - /Color -->

