	<Design.PreviewWith>
		<PreviewCodeSnippet MaxWidth="700">
			<StackPanel Orientation="Horizontal"
					Spacing="14">
				<StackPanel Spacing="8"
						Orientation="Horizontal"
						VerticalAlignment="Center">
					<TextBlock Text="Height" />
					<TextBlock Text="{Binding ElementName=Default, Path=Bounds.Height}" />
				</StackPanel>
				<Grid Background="Blue">
					<CheckBox IsChecked="True" />
				</Grid>
				<CheckBox Name="Default"
						Content="Default"
						IsChecked="True" />
				<CheckBox Content="Default"
						IsChecked="False" />
				<CheckBox Content="Indeterminate"
						IsThreeState="True"
						IsChecked="{x:Null}" />
				<CheckBox Content="Default"
						IsChecked="True"
						IsEnabled="False" />
				<CheckBox Content="Indeterminate"
						IsThreeState="True"
						IsChecked="{x:Null}"
						IsEnabled="False" />
			</StackPanel>
			<PreviewCodeSnippet.ItemTemplate>
				<DataTemplate DataType="ThemeColor">
					<StackPanel Width="160">
						<CheckBox Theme.Color="{Binding}"
								Content="{Binding}"
								IsChecked="True" />
						<CheckBox Theme.Color="{Binding}"
								Content="{Binding}"
								IsChecked="False" />
						<CheckBox Theme.Color="{Binding}"
								Content="Indeterminate"
								IsThreeState="True"
								IsChecked="{x:Null}" />
						<CheckBox Theme.Color="{Binding}"
								Content="{Binding}"
								IsChecked="True"
								IsEnabled="False" />
						<CheckBox Theme.Color="{Binding}"
								Content="Indeterminate"
								IsThreeState="True"
								IsChecked="{x:Null}"
								IsEnabled="False" />
					</StackPanel>
				</DataTemplate>

			</PreviewCodeSnippet.ItemTemplate>
		</PreviewCodeSnippet>
	</Design.PreviewWith>
</ResourceDictionary>