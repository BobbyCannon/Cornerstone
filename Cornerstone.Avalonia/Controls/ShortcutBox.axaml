				<Style Selector="^ /template/ Border#PART_Border">
					<Setter Property="Background" Value="{DynamicResource Teal05}" />
				</Style>
			</Style>
		</Style>
		<!-- Generated Code - /Colors -->
	</ControlTheme>

	<Design.PreviewWith>
		<PreviewCodeSnippet Width="600">
			<PreviewCodeSnippet.Styles>
				<Style Selector="StackPanel">
					<Setter Property="Orientation" Value="Horizontal" />
					<Setter Property="Margin" Value="20,0,0,0" />
					<Setter Property="Spacing" Value="4" />
				</Style>
				<Style Selector="TextBlock">
					<Setter Property="VerticalAlignment" Value="Center" />
				</Style>
			</PreviewCodeSnippet.Styles>
			<WrapPanel ItemSpacing="10"
					LineSpacing="10">
				<ShortcutBox x:Name="Input"
						MinWidth="200"
						Watermark="enter shortcut">
					<ShortcutBox.Binding>
						<ShortcutBinding Key="Left" KeyModifiers="Alt" />
					</ShortcutBox.Binding>
				</ShortcutBox>
				<StackPanel>
					<TextBlock Text="Button:" />
					<TextBlock Text="{Binding ElementName=Input, Path=Binding.GamepadButton}" />
				</StackPanel>
				<StackPanel>
					<TextBlock Text="Key" />
					<TextBlock Text="{Binding ElementName=Input, Path=Binding.Key}" />
				</StackPanel>
				<StackPanel>
					<TextBlock Text="Modifiers:" />
					<TextBlock Text="{Binding ElementName=Input, Path=Binding.KeyModifiers}" />
				</StackPanel>
				<ShortcutBox IsTriggered="True"
						Label="Key Binding"
						Watermark="Is Triggered"
						Width="200" />
			</WrapPanel>
			<PreviewCodeSnippet.ItemTemplate>
				<DataTemplate DataType="ThemeColor">
					<StackPanel Orientation="Vertical">
						<ShortcutBox
								Label="{Binding}"
								Theme.Color="{Binding}"
								MinWidth="120">
							<ShortcutBox.Binding>
								<ShortcutBinding Key="A" KeyModifiers="Alt"
										SecondKey="B" SecondKeyModifiers="Control" />
							</ShortcutBox.Binding>
						</ShortcutBox>
						<ShortcutBox
								Label="Triggered"
								Theme.Color="{Binding}"
								IsTriggered="True"
								MinWidth="160">
							<ShortcutBox.Binding>
								<ShortcutBinding Key="A" KeyModifiers="Alt" />
							</ShortcutBox.Binding>
						</ShortcutBox>
					</StackPanel>
				</DataTemplate>
			</PreviewCodeSnippet.ItemTemplate>
		</PreviewCodeSnippet>
	</Design.PreviewWith>
</ResourceDictionary>