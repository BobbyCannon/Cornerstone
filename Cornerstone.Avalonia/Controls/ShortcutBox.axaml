				</Style>
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Teal]">
			<Style Selector="^ /template/ TextBlock#PART_Watermark">
				<Setter Property="Foreground" Value="{DynamicResource Teal05}" />
			</Style>
			<Style Selector="^:focus">
				<Setter Property="BorderBrush" Value="{DynamicResource Teal05}" />
			</Style>
			<Style Selector="^[IsTriggered=True]">
