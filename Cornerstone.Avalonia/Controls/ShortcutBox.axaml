		</Style>
		<Style Selector="^[(Theme.Color)=Red]">
			<Style Selector="^ /template/ TextBlock#PART_Watermark">
				<Setter Property="Foreground" Value="{DynamicResource Red05}" />
			</Style>
			<Style Selector="^:focus">
				<Setter Property="BorderBrush" Value="{DynamicResource Red05}" />
			</Style>
			<Style Selector="^[IsTriggered=True]">
				<Setter Property="Foreground" Value="{DynamicResource RedText05}" />
				<Style Selector="^ /template/ Border#PART_Border">
