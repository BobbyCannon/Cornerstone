<ResourceDictionary
		xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:ClassModifier="internal">

	<ControlTheme x:Key="SliderHorizontalRepeatButton" TargetType="RepeatButton">
		<Setter Property="Template">
			<ControlTemplate>
				<Grid>
					<Border
							Name="FocusTarget"
							Margin="0,-10"
							Background="Transparent" />
					<Border
							Name="TrackBackground"
							Background="{TemplateBinding Background}"
							CornerRadius="8"
							Height="8"
							UseLayoutRounding="False"
							VerticalAlignment="Center"
							Margin="0" />
				</Grid>
			</ControlTemplate>
		</Setter>
	</ControlTheme>

	<ControlTheme x:Key="SliderVerticalRepeatButton" TargetType="RepeatButton">
		<Setter Property="Template">
			<ControlTemplate>
				<Grid>
					<Border
							x:Name="FocusTarget"
							Margin="0,-10"
							Background="Transparent" />
					<Border
							x:Name="TrackBackground"
							Background="{TemplateBinding Background}"
							CornerRadius="8"
							Width="8"
							UseLayoutRounding="False"
							HorizontalAlignment="Center" />
				</Grid>
			</ControlTemplate>
		</Setter>
	</ControlTheme>

	<ControlTheme x:Key="SliderThumbTheme" TargetType="Thumb">
		<Setter Property="Template">
			<ControlTemplate>
				<Border
						Background="{TemplateBinding Background}"
						BorderBrush="{TemplateBinding BorderBrush}"
						BorderThickness="{TemplateBinding BorderThickness}"
						CornerRadius="8">
					<Border
							Background="{TemplateBinding Foreground}"
							Height="8"
							Width="8"
							CornerRadius="4" />
				</Border>
			</ControlTemplate>
		</Setter>
	</ControlTheme>

	<ControlTheme x:Key="{x:Type Slider}" TargetType="Slider">
		<Setter Property="Theme.Color" Value="Current" />
		<Setter Property="Background" Value="{DynamicResource Background04}" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Foreground" Value="{DynamicResource Foreground00}" />
		<Setter Property="FontSize" Value="{DynamicResource ControlFontSize}" />
		<Setter Property="Minimum" Value="0" />
		<Setter Property="Maximum" Value="100" />
		<Setter Property="Value" Value="0" />
		<Setter Property="TickFrequency" Value="1" />
		<Setter Property="IsSnapToTickEnabled" Value="True" />

		<Style Selector="^:horizontal">
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="Template">
				<ControlTemplate>
					<DataValidationErrors>
						<Grid ColumnDefinitions="Auto,*">
							<TextBlock x:Name="Label"
								Margin="0,0,20,0"
								Text="{TemplateBinding (ControlHelper.DisplayName)}"
								IsVisible="{TemplateBinding (ControlHelper.DisplayName), Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

							<Border Grid.Column="1"
									BorderBrush="{TemplateBinding BorderBrush}"
									BorderThickness="{TemplateBinding BorderThickness}"
									CornerRadius="{TemplateBinding CornerRadius}">
								<Grid x:Name="SliderContainer"
										Margin="{TemplateBinding Padding}">
									<Grid.Styles>
										<Style Selector="TickBar">
											<Setter Property="ReservedSpace" Value="{Binding #PART_Track.Thumb.Bounds}" />
										</Style>
									</Grid.Styles>
									<Grid
											x:Name="HorizontalTemplate"
											MinHeight="{DynamicResource SliderHorizontalHeight}"
											ColumnDefinitions="Auto,Auto,*"
											RowDefinitions="Auto,Auto,Auto">
										<TickBar
												Name="TopTickBar"
												Grid.Row="0" Grid.ColumnSpan="3" Grid.Column="0"
												Ticks="{TemplateBinding Ticks}"
												TickFrequency="{TemplateBinding Slider.TickFrequency}"
												Orientation="{TemplateBinding Slider.Orientation}"
												Minimum="{TemplateBinding Slider.Minimum}"
												Maximum="{TemplateBinding Slider.Maximum}"
												Height="6"
												Margin="0,0,0,0"
												VerticalAlignment="Bottom"
												Placement="Top"
												IsVisible="False"
												Fill="{DynamicResource SliderTickBarFill}" />
										<TickBar
												Name="BottomTickBar"
												Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
												Ticks="{TemplateBinding Ticks}"
												TickFrequency="{TemplateBinding Slider.TickFrequency}"
												Orientation="{TemplateBinding Slider.Orientation}"
												Minimum="{TemplateBinding Slider.Minimum}"
												Maximum="{TemplateBinding Slider.Maximum}"
												Height="6"
												Margin="0,0,0,0"
												VerticalAlignment="Top"
												Placement="Bottom"
												IsVisible="False"
												Fill="{DynamicResource SliderTickBarFill}" />
										<Track
												Name="PART_Track"
												Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
												Minimum="{TemplateBinding Minimum}"
												Maximum="{TemplateBinding Maximum}"
												Value="{TemplateBinding Value, Mode=TwoWay}"
												IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
												Orientation="Horizontal">
											<Track.DecreaseButton>
												<RepeatButton
														Name="PART_DecreaseButton"
														Theme="{StaticResource SliderHorizontalRepeatButton}"
														Background="{TemplateBinding Foreground}"
														Focusable="False"
														Margin="0,0,-8,0" />
											</Track.DecreaseButton>
											<Track.IncreaseButton>
												<RepeatButton
														Name="PART_IncreaseButton"
														Theme="{StaticResource SliderHorizontalRepeatButton}"
														Background="{TemplateBinding Background}"
														Focusable="False"
														Margin="-8,0,0,0" />
											</Track.IncreaseButton>
											<Thumb
													Name="thumb"
													Width="20"
													Height="20"
													Margin="0"
													Padding="0"
													Background="{DynamicResource Background04}"
													Foreground="{DynamicResource Foreground04}"
													BorderThickness="0"
													Theme="{StaticResource SliderThumbTheme}"
													DataContext="{TemplateBinding Value}" />
										</Track>
									</Grid>
								</Grid>
							</Border>
						</Grid>
					</DataValidationErrors>
				</ControlTemplate>
			</Setter>
		</Style>

		<Style Selector="^:vertical">
			<Setter Property="HorizontalAlignment" Value="Center" />
			<Setter Property="Template">
				<ControlTemplate>
					<DataValidationErrors>
						<Border
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="{TemplateBinding CornerRadius}">
							<Grid x:Name="SliderContainer"
									Margin="{TemplateBinding Padding}">
								<Grid.Styles>
									<Style Selector="TickBar">
										<Setter Property="ReservedSpace" Value="{Binding #PART_Track.Thumb.Bounds}" />
									</Style>
								</Grid.Styles>
								<Grid
										x:Name="VerticalTemplate"
										MinWidth="20"
										ColumnDefinitions="Auto,Auto,Auto"
										RowDefinitions="*,Auto,Auto">

									<TickBar
											Name="LeftTickBar"
											Grid.RowSpan="3"
											Ticks="{TemplateBinding Ticks}"
											TickFrequency="{TemplateBinding Slider.TickFrequency}"
											Orientation="{TemplateBinding Slider.Orientation}"
											Minimum="{TemplateBinding Slider.Minimum}"
											Maximum="{TemplateBinding Slider.Maximum}"
											Width="6"
											Margin="0,0,0,0"
											HorizontalAlignment="Right"
											Placement="Left"
											IsVisible="False"
											Fill="{DynamicResource Background04}" />
									<TickBar
											Name="RightTickBar"
											Grid.Row="0" Grid.RowSpan="3"
											Grid.Column="2"
											Ticks="{TemplateBinding Ticks}"
											TickFrequency="{TemplateBinding Slider.TickFrequency}"
											Orientation="{TemplateBinding Slider.Orientation}"
											Minimum="{TemplateBinding Slider.Minimum}"
											Maximum="{TemplateBinding Slider.Maximum}"
											Width="6"
											Margin="0,0,0,0"
											HorizontalAlignment="Left"
											Placement="Right"
											IsVisible="False"
											Fill="{DynamicResource Background04}" />
									<Track
											Name="PART_Track"
											Grid.Row="0" Grid.RowSpan="3"
											Grid.Column="1"
											Minimum="{TemplateBinding Minimum}"
											Maximum="{TemplateBinding Maximum}"
											Value="{TemplateBinding Value, Mode=TwoWay}"
											IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
											Orientation="Vertical">
										<Track.DecreaseButton>
											<RepeatButton
													Name="PART_DecreaseButton"
													Theme="{StaticResource SliderVerticalRepeatButton}"
													Background="{TemplateBinding Foreground}"
													Focusable="False"
													Margin="0,-8,0,0" />
										</Track.DecreaseButton>
										<Track.IncreaseButton>
											<RepeatButton
													Name="PART_IncreaseButton"
													Background="{TemplateBinding Background}"
													Theme="{StaticResource SliderVerticalRepeatButton}"
													Focusable="False"
													Margin="0,0,0,-8" />
										</Track.IncreaseButton>
										<Thumb
												Name="SliderThumb"
												Width="20"
												Height="20"
												Margin="0"
												Padding="0"
												Background="{DynamicResource Background04}"
												Foreground="{DynamicResource Foreground04}"
												BorderThickness="0"
												Theme="{StaticResource SliderThumbTheme}"
												DataContext="{TemplateBinding Value}" />
									</Track>
								</Grid>
							</Grid>
						</Border>
					</DataValidationErrors>
				</ControlTemplate>
			</Setter>
		</Style>

		<Style Selector="^[TickPlacement=TopLeft] /template/ TickBar#LeftTickBar, ^[TickPlacement=Outside] /template/ TickBar#LeftTickBar">
			<Setter Property="IsVisible" Value="True" />
		</Style>

		<Style Selector="^[TickPlacement=TopLeft] /template/ TickBar#TopTickBar, ^[TickPlacement=Outside] /template/ TickBar#TopTickBar">
			<Setter Property="IsVisible" Value="True" />
		</Style>

		<Style Selector="^[TickPlacement=BottomRight] /template/ TickBar#BottomTickBar, ^[TickPlacement=Outside] /template/ TickBar#BottomTickBar">
			<Setter Property="IsVisible" Value="True" />
		</Style>

		<Style Selector="^[TickPlacement=BottomRight] /template/ TickBar#RightTickBar, ^[TickPlacement=Outside] /template/ TickBar#RightTickBar">
			<Setter Property="IsVisible" Value="True" />
		</Style>

		<Style Selector="^[IsDirectionReversed=True]">

			<Style Selector="^:horizontal /template/ RepeatButton#PART_DecreaseButton">
				<Setter Property="Margin" Value="-8,0,0,0" />
			</Style>

			<Style Selector="^:horizontal /template/ RepeatButton#PART_IncreaseButton">
				<Setter Property="Margin" Value="0,0,-8,0" />
			</Style>

			<Style Selector="^:vertical /template/ RepeatButton#PART_DecreaseButton">
				<Setter Property="Margin" Value="0,0,0,-8" />
			</Style>

			<Style Selector="^:vertical /template/ RepeatButton#PART_IncreaseButton">
				<Setter Property="Margin" Value="0,-8,0,0" />
			</Style>

		</Style>

		<Style Selector="^[(Theme.Color)=None]">
			<Style Selector="^ /template/ Thumb">
				<Setter Property="Background" Value="{DynamicResource Background07}" />
			</Style>
			<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
				<Setter Property="Background" Value="{DynamicResource Background05}" />
			</Style>
			<Style Selector="^:pointerover">
				<Style Selector="^ /template/ Thumb">
					<Setter Property="Background" Value="{DynamicResource Background06}" />
				</Style>
				<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
					<Setter Property="Background" Value="{DynamicResource Background04}" />
				</Style>
			</Style>
			<Style Selector="^:pressed">
				<Style Selector="^ /template/ Thumb">
					<Setter Property="Background" Value="{DynamicResource Background06}" />
				</Style>
				<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
					<Setter Property="Background" Value="{DynamicResource Background04}" />
				</Style>
			</Style>
			<Style Selector="^:disabled">
				<Style Selector="^ /template/ Thumb">
					<Setter Property="Background" Value="{DynamicResource Background03}" />
					<Setter Property="Foreground" Value="{DynamicResource Background01}" />
				</Style>
				<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
					<Setter Property="Background" Value="{DynamicResource Background02}" />
				</Style>
			</Style>
		</Style>

		<!-- Code Template - Color -->
		<Style Selector="^[(Theme.Color)=Current]">
			<Style Selector="^ /template/ Thumb">
				<Setter Property="Background" Value="{DynamicResource ThemeColor07}" />
			</Style>
			<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
				<Setter Property="Background" Value="{DynamicResource ThemeColor05}" />
			</Style>
			<Style Selector="^:pointerover">
				<Style Selector="^ /template/ Thumb">
					<Setter Property="Background" Value="{DynamicResource ThemeColor06}" />
				</Style>
				<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
					<Setter Property="Background" Value="{DynamicResource ThemeColor04}" />
				</Style>
			</Style>
			<Style Selector="^:pressed">
				<Style Selector="^ /template/ Thumb">
					<Setter Property="Background" Value="{DynamicResource ThemeColor06}" />
				</Style>
				<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
					<Setter Property="Background" Value="{DynamicResource ThemeColor04}" />
				</Style>
			</Style>
			<Style Selector="^:disabled">
				<Style Selector="^ /template/ Thumb">
					<Setter Property="Background" Value="{DynamicResource ThemeColor03}" />
					<Setter Property="Foreground" Value="{DynamicResource ThemeColor01}" />
				</Style>
				<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
					<Setter Property="Background" Value="{DynamicResource ThemeColor02}" />
				</Style>
			</Style>
		</Style>
		<!-- Code Template - /Color -->

		<!-- Generated Code - Colors -->
		<Style Selector="^[(Theme.Color)=Amber]">
			<Style Selector="^ /template/ Thumb">
				<Setter Property="Background" Value="{DynamicResource Amber07}" />
			</Style>
			<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
				<Setter Property="Background" Value="{DynamicResource Amber05}" />
			</Style>
			<Style Selector="^:pointerover">
				<Style Selector="^ /template/ Thumb">
					<Setter Property="Background" Value="{DynamicResource Amber06}" />
				</Style>
				<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
					<Setter Property="Background" Value="{DynamicResource Amber04}" />
				</Style>
			</Style>
			<Style Selector="^:pressed">
				<Style Selector="^ /template/ Thumb">
					<Setter Property="Background" Value="{DynamicResource Amber06}" />
				</Style>
				<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
					<Setter Property="Background" Value="{DynamicResource Amber04}" />
				</Style>
			</Style>
			<Style Selector="^:disabled">
				<Style Selector="^ /template/ Thumb">
					<Setter Property="Background" Value="{DynamicResource Amber03}" />
					<Setter Property="Foreground" Value="{DynamicResource Amber01}" />
				</Style>
				<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
					<Setter Property="Background" Value="{DynamicResource Amber02}" />
				</Style>
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Blue]">
			<Style Selector="^ /template/ Thumb">
				<Setter Property="Background" Value="{DynamicResource Blue07}" />
			</Style>
			<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
				<Setter Property="Background" Value="{DynamicResource Blue05}" />
			</Style>
			<Style Selector="^:pointerover">
				<Style Selector="^ /template/ Thumb">
					<Setter Property="Background" Value="{DynamicResource Blue06}" />
				</Style>
				<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
					<Setter Property="Background" Value="{DynamicResource Blue04}" />
				</Style>
			</Style>
			<Style Selector="^:pressed">
				<Style Selector="^ /template/ Thumb">
					<Setter Property="Background" Value="{DynamicResource Blue06}" />
				</Style>
				<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
					<Setter Property="Background" Value="{DynamicResource Blue04}" />
				</Style>
			</Style>
			<Style Selector="^:disabled">
				<Style Selector="^ /template/ Thumb">
					<Setter Property="Background" Value="{DynamicResource Blue03}" />
					<Setter Property="Foreground" Value="{DynamicResource Blue01}" />
				</Style>
				<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
					<Setter Property="Background" Value="{DynamicResource Blue02}" />
				</Style>
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=BlueGray]">
			<Style Selector="^ /template/ Thumb">
				<Setter Property="Background" Value="{DynamicResource BlueGray07}" />
			</Style>
			<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
				<Setter Property="Background" Value="{DynamicResource BlueGray05}" />
			</Style>
			<Style Selector="^:pointerover">
				<Style Selector="^ /template/ Thumb">
					<Setter Property="Background" Value="{DynamicResource BlueGray06}" />
				</Style>
				<Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
					<Setter Property="Background" Value="{DynamicResource BlueGray04}" />
				</Style>
			</Style>
			<Style Selector="^:pressed">
