	<!-- ReSharper disable Xaml.MissingGridIndex -->
	<Design.PreviewWith>
		<PreviewCodeSnippet MaxWidth="600">
			<AutoGrid RowCount="3"
					RowSpacing="20">
				<Slider ControlHelper.DisplayName="Foo Value"
						Value="50"
						/>
				<ItemsControl ItemsSource="{x:Static Theme.ThemeColors}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel
									ItemSpacing="10"
									LineSpacing="20" />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate DataType="ThemeColor">
							<StackPanel Spacing="10"
									Width="160">
								<Slider Theme.Color="{Binding}"
										Value="50" />
							</StackPanel>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
				<ItemsControl ItemsSource="{x:Static Theme.ThemeColors}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel
									ItemSpacing="10"
									LineSpacing="20" />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate DataType="ThemeColor">
							<StackPanel Spacing="10"
									Orientation="Horizontal"
									Height="120">
								<Slider Theme.Color="{Binding}"
										Value="50"
										Orientation="Vertical" />
							</StackPanel>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</AutoGrid>
		</PreviewCodeSnippet>
	</Design.PreviewWith>
