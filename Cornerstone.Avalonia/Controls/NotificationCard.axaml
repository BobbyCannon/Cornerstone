<ResourceDictionary
		xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:ClassModifier="internal">
	<!--<SolidColorBrush x:Key="NotificationCardProgressBackground" Color="{DynamicResource Background05}" />
	<SolidColorBrush x:Key="NotificationCardBackgroundInformation" Color="{DynamicResource Blue07}" />
	<SolidColorBrush x:Key="NotificationCardBackgroundSuccess" Color="{DynamicResource Green07}" />
	<SolidColorBrush x:Key="NotificationCardBackgroundWarning" Color="{DynamicResource Orange07}" />
	<SolidColorBrush x:Key="NotificationCardBackgroundError" Color="{DynamicResource Red07}" />-->

	<ControlTheme x:Key="{x:Type NotificationCard}" TargetType="NotificationCard">
		<Setter Property="Background" Value="{DynamicResource Background04}" />
		<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
		<Setter Property="Foreground" Value="{DynamicResource Foreground00}" />
		<Setter Property="FontSize" Value="{DynamicResource ControlFontSize}" />
		<Setter Property="Padding" Value="10" />
		<Setter Property="RenderTransformOrigin" Value="50%,75%" />
		<Setter Property="UseLayoutRounding" Value="True" />
		<Setter Property="Width" Value="350" />
		<Setter Property="Template">
			<ControlTemplate>
				<LayoutTransformControl
						Name="PART_LayoutTransformControl"
						UseRenderTransform="True">
					<Border
							CornerRadius="{TemplateBinding CornerRadius}"
							BoxShadow="{DynamicResource ShadowDepth2}"
							Margin="8">
						<Border
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="{TemplateBinding CornerRadius}"
								ClipToBounds="True">
							<DockPanel>
								<Panel x:Name="PART_HeaderBar"
										Height="4"
										Background="{StaticResource Blue05}"
										DockPanel.Dock="Top" />
								<ContentControl
										Name="PART_Content"
										MinHeight="64"
										Padding="{TemplateBinding Padding}"
										Content="{TemplateBinding Content}"
										Foreground="{TemplateBinding Foreground}" />
							</DockPanel>
						</Border>
					</Border>
				</LayoutTransformControl>
			</ControlTemplate>
		</Setter>
		<ControlTheme.Animations>
			<Animation Duration="0:0:0.45" Easing="QuadraticEaseIn" FillMode="Forward">
				<KeyFrame Cue="0%">
					<Setter Property="Opacity" Value="0" />
					<Setter Property="TranslateTransform.Y" Value="20" />
					<Setter Property="ScaleTransform.ScaleX" Value="0.85" />
					<Setter Property="ScaleTransform.ScaleY" Value="0.85" />
				</KeyFrame>
				<KeyFrame Cue="30%">
					<Setter Property="TranslateTransform.Y" Value="-20" />
				</KeyFrame>
				<KeyFrame Cue="100%">
					<Setter Property="Opacity" Value="1" />
					<Setter Property="TranslateTransform.Y" Value="0" />
					<Setter Property="ScaleTransform.ScaleX" Value="1" />
					<Setter Property="ScaleTransform.ScaleY" Value="1" />
				</KeyFrame>
			</Animation>
		</ControlTheme.Animations>

		<!-- Closing animation. -->

		<Style Selector="^.right[IsClosing=true] /template/ LayoutTransformControl#PART_LayoutTransformControl">
			<Setter Property="RenderTransformOrigin" Value="50%,0%" />
			<Style.Animations>
				<Animation Duration="0:0:0.75" Easing="QuadraticEaseOut" FillMode="Forward">
					<KeyFrame Cue="0%">
						<Setter Property="TranslateTransform.X" Value="0" />
						<Setter Property="ScaleTransform.ScaleY" Value="1" />
					</KeyFrame>
					<KeyFrame Cue="70%">
						<Setter Property="TranslateTransform.X" Value="800" />
						<Setter Property="ScaleTransform.ScaleY" Value="1" />
					</KeyFrame>
					<KeyFrame Cue="100%">
						<Setter Property="TranslateTransform.X" Value="800" />
						<Setter Property="ScaleTransform.ScaleY" Value="0" />
					</KeyFrame>
				</Animation>
			</Style.Animations>
		</Style>
		<Style Selector="^.left[IsClosing=true] /template/ LayoutTransformControl#PART_LayoutTransformControl">
			<Setter Property="RenderTransformOrigin" Value="50%,0%" />
			<Style.Animations>
				<Animation Duration="0:0:0.75" Easing="QuadraticEaseOut" FillMode="Forward">
					<KeyFrame Cue="0%">
						<Setter Property="TranslateTransform.X" Value="0" />
						<Setter Property="ScaleTransform.ScaleY" Value="1" />
					</KeyFrame>
					<KeyFrame Cue="70%">
						<Setter Property="TranslateTransform.X" Value="-800" />
						<Setter Property="ScaleTransform.ScaleY" Value="1" />
					</KeyFrame>
					<KeyFrame Cue="100%">
						<Setter Property="TranslateTransform.X" Value="-800" />
						<Setter Property="ScaleTransform.ScaleY" Value="0" />
					</KeyFrame>
				</Animation>
			</Style.Animations>
		</Style>
		<Style Selector="^.top[IsClosing=true] /template/ LayoutTransformControl#PART_LayoutTransformControl">
			<Setter Property="RenderTransformOrigin" Value="50%,0%" />
			<Style.Animations>
				<Animation Duration="0:0:0.75" Easing="QuadraticEaseOut" FillMode="Forward">
					<KeyFrame Cue="0%">
						<Setter Property="TranslateTransform.Y" Value="0" />
						<Setter Property="ScaleTransform.ScaleY" Value="1" />
					</KeyFrame>
					<KeyFrame Cue="70%">
						<Setter Property="TranslateTransform.Y" Value="-200" />
						<Setter Property="ScaleTransform.ScaleY" Value="1" />
					</KeyFrame>
					<KeyFrame Cue="100%">
						<Setter Property="TranslateTransform.Y" Value="-200" />
						<Setter Property="ScaleTransform.ScaleY" Value="0" />
					</KeyFrame>
				</Animation>
			</Style.Animations>
		</Style>
		<Style Selector="^.bottom[IsClosing=true] /template/ LayoutTransformControl#PART_LayoutTransformControl">
			<Setter Property="RenderTransformOrigin" Value="50%,0%" />
			<Style.Animations>
				<Animation Duration="0:0:0.75" Easing="QuadraticEaseOut" FillMode="Forward">
					<KeyFrame Cue="0%">
						<Setter Property="TranslateTransform.Y" Value="0" />
						<Setter Property="ScaleTransform.ScaleY" Value="1" />
					</KeyFrame>
					<KeyFrame Cue="70%">
						<Setter Property="TranslateTransform.Y" Value="200" />
						<Setter Property="ScaleTransform.ScaleY" Value="1" />
					</KeyFrame>
					<KeyFrame Cue="100%">
						<Setter Property="TranslateTransform.Y" Value="200" />
						<Setter Property="ScaleTransform.ScaleY" Value="0" />
					</KeyFrame>
				</Animation>
			</Style.Animations>
		</Style>

		<!-- Closing animation. -->

		<Style Selector="^[IsClosing=true]">
			<Style.Animations>
				<Animation Duration="0:0:1.25" Easing="QuadraticEaseOut" FillMode="Forward">
					<KeyFrame Cue="100%">
						<Setter Property="IsClosed" Value="True" />
					</KeyFrame>
				</Animation>
			</Style.Animations>
		</Style>
		<Style Selector="^:information /template/ Panel#PART_HeaderBar">
			<Setter Property="Background" Value="{StaticResource Blue05}" />
		</Style>
		<Style Selector="^:success /template/ Panel#PART_HeaderBar">
			<Setter Property="Background" Value="{StaticResource Green05}" />
		</Style>
		<Style Selector="^:warning /template/ Panel#PART_HeaderBar">
			<Setter Property="Background" Value="{StaticResource Orange05}" />
		</Style>
		<Style Selector="^:error /template/ Panel#PART_HeaderBar">
			<Setter Property="Background" Value="{StaticResource Red05}" />
		</Style>
	</ControlTheme>

	<Design.PreviewWith>
		<Border Padding="16">
			<StackPanel>
				<NotificationCard Content="Information" NotificationType="Information" />
				<NotificationCard Content="Success" NotificationType="Success" />
				<NotificationCard Content="Warning" NotificationType="Warning" />
				<NotificationCard Content="Error" NotificationType="Error" />
				<NotificationCard>
					<NotificationCard.Content>
						<Notification Message="Test" />
					</NotificationCard.Content>
				</NotificationCard>
				<NotificationCard NotificationType="Error">
					<NotificationCard.Content>
						<Notification Message="Message" Title="Title" Type="Information" />
					</NotificationCard.Content>
				</NotificationCard>
			</StackPanel>
		</Border>
	</Design.PreviewWith>
</ResourceDictionary>