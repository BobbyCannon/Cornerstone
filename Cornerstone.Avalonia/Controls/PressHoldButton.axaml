			</Style>
		</Style>
		<!-- Generated Code - /Colors -->
	</ControlTheme>

	<Design.PreviewWith>
		<PreviewCodeSnippet MaxWidth="600">
			<WrapPanel ItemSpacing="10"
					LineSpacing="10">
				<StackPanel Classes="Sample"
						Spacing="8"
						Orientation="Horizontal"
						VerticalAlignment="Center">
					<TextBlock Text="Height" />
					<TextBlock Text="{Binding ElementName=Default, Path=Bounds.Height}" />
				</StackPanel>
				<PressHoldButton x:Name="Default">Default</PressHoldButton>
				<PressHoldButton Height="24">Short (24px)</PressHoldButton>
			</WrapPanel>
			<PreviewCodeSnippet.ItemTemplate>
				<DataTemplate DataType="ThemeColor">
					<StackPanel Spacing="4">
						<PressHoldButton
								Content="{Binding}"
								Theme.Color="{Binding}"
								Width="120" />
						<PressHoldButton
								Content="Disabled"
								Theme.Color="{Binding}"
								IsEnabled="False"
								Width="120" />
					</StackPanel>
				</DataTemplate>
			</PreviewCodeSnippet.ItemTemplate>
		</PreviewCodeSnippet>
	</Design.PreviewWith>
</ResourceDictionary>