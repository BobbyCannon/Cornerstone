			</Style>
			<Style Selector="^:disabled">
				<Setter Property="Background" Value="{DynamicResource DeepPurple03}" />
				<Setter Property="Foreground" Value="{DynamicResource ThemeText03}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Gray]">
			<Setter Property="HoldBackground" Value="{DynamicResource Gray07}" />
			<Setter Property="Background" Value="{DynamicResource Gray05}" />
			<Style Selector="^:pointerover">
				<Setter Property="Background" Value="{DynamicResource Gray06}" />
			</Style>
			<Style Selector="^:pressed">
				<Setter Property="Background" Value="{DynamicResource Gray06}" />
			</Style>
			<Style Selector="^:disabled">
				<Setter Property="Background" Value="{DynamicResource Gray03}" />
				<Setter Property="Foreground" Value="{DynamicResource ThemeText03}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Green]">
			<Setter Property="HoldBackground" Value="{DynamicResource Green07}" />
			<Setter Property="Background" Value="{DynamicResource Green05}" />
			<Style Selector="^:pointerover">
