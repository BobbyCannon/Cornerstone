<ResourceDictionary
		xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:ClassModifier="internal">

	<ControlTheme x:Key="ScrollBarRepeatButton" TargetType="{x:Type RepeatButton}">
		<Setter Property="Theme.Color" Value="Current" />
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="Foreground" Value="Gray" />
		<Setter Property="Template">
			<ControlTemplate>
				<Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
					<ContentPresenter
							HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
							VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
							Content="{TemplateBinding Content}"
							Foreground="{TemplateBinding Foreground}" />
				</Border>
			</ControlTemplate>
		</Setter>
	</ControlTheme>
	<ControlTheme x:Key="{x:Type ScrollBar}" TargetType="ScrollBar">
		<Setter Property="Theme.Color" Value="Current" />
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="AllowAutoHide" Value="True" />
		<Setter Property="Cursor" Value="Arrow" />
		<Style Selector="^:horizontal">
			<Setter Property="Background" Value="{DynamicResource Background05}" />
			<Setter Property="Height" Value="4" />
			<Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
			<Setter Property="Template">
				<ControlTemplate>
					<Border x:Name="Root"
							Background="{TemplateBinding Background}"
							CornerRadius="{TemplateBinding CornerRadius}"
							Height="{TemplateBinding Height }"
							VerticalAlignment="Center"
							UseLayoutRounding="False">
						<Grid ColumnDefinitions="Auto,*,Auto">
							<Track Grid.Column="1"
									Maximum="{TemplateBinding Maximum}"
									Minimum="{TemplateBinding Minimum}"
									Orientation="{TemplateBinding Orientation}"
									ViewportSize="{TemplateBinding ViewportSize}"
									Value="{TemplateBinding Value, Mode=TwoWay}">
								<Track.DecreaseButton>
									<RepeatButton Name="PART_PageUpButton"
											Focusable="False"
											Theme="{DynamicResource ScrollBarRepeatButton}"
											HorizontalAlignment="Stretch" />
								</Track.DecreaseButton>
								<Track.IncreaseButton>
									<RepeatButton Name="PART_PageDownButton"
											Focusable="False"
											Theme="{DynamicResource ScrollBarRepeatButton}"
											HorizontalAlignment="Stretch" />
								</Track.IncreaseButton>
								<Thumb Name="Thumb" />
							</Track>
						</Grid>
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="^:vertical">
			<Setter Property="Background" Value="{DynamicResource Background05}" />
			<Setter Property="Width" Value="4" />
			<Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
			<Setter Property="Template">
				<ControlTemplate>
					<Border x:Name="Root"
							Background="{TemplateBinding Background}"
							CornerRadius="{TemplateBinding CornerRadius}"
							Width="{TemplateBinding Width}"
							HorizontalAlignment="Center"
							UseLayoutRounding="False">
						<Track IsDirectionReversed="True"
								Maximum="{TemplateBinding Maximum}"
								Minimum="{TemplateBinding Minimum}"
								Orientation="{TemplateBinding Orientation}"
								ViewportSize="{TemplateBinding ViewportSize}"
								Value="{TemplateBinding Value, Mode=TwoWay}">
							<Track.DecreaseButton>
								<RepeatButton Name="PART_PageUpButton"
										Focusable="False"
										Theme="{DynamicResource ScrollBarRepeatButton}"
										VerticalAlignment="Stretch" />
							</Track.DecreaseButton>
							<Track.IncreaseButton>
								<RepeatButton Name="PART_PageDownButton"
										Focusable="False"
										Theme="{DynamicResource ScrollBarRepeatButton}"
										VerticalAlignment="Stretch" />
							</Track.IncreaseButton>
							<Thumb Name="Thumb" />
						</Track>
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="^ /template/ Thumb#Thumb">
			<Setter Property="Background" Value="{DynamicResource Background08}" />
			<Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate>
						<Border Background="{TemplateBinding Background}"
								CornerRadius="{TemplateBinding CornerRadius}" />
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style Selector="^ /template/ Thumb#Thumb:pointerover">
			<Setter Property="Background" Value="{DynamicResource Background09}" />
		</Style>
		<Style Selector="^ /template/ Thumb#Thumb:pressed">
			<Setter Property="Background" Value="{DynamicResource Background06}" />
		</Style>
		<Style Selector="^:horizontal /template/ Thumb#Thumb">
			<Setter Property="MinWidth" Value="24" />
			<Setter Property="Height" Value="{DynamicResource ScrollBarThumbThickness}" />
		</Style>
		<Style Selector="^:vertical /template/ Thumb#Thumb">
			<Setter Property="MinHeight" Value="24" />
			<Setter Property="Width" Value="{DynamicResource ScrollBarThumbThickness}" />
		</Style>
		<Style Selector="^[IsExpanded=true]">
			<Style Selector="^:horizontal">
				<Setter Property="Height" Value="10" />
			</Style>
			<Style Selector="^:vertical">
				<Setter Property="Width" Value="10" />
			</Style>
		</Style>

		<!-- Code Template - Color -->
		<Style Selector="^[(Theme.Color)=Current]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource ThemeColor05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource ThemeColor05}" />
			</Style>
		</Style>
		<!-- Code Template - /Color -->

		<!-- Generated Code - Colors -->
		<Style Selector="^[(Theme.Color)=Amber]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource Amber05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource Amber05}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Blue]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource Blue05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource Blue05}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=BlueGray]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource BlueGray05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource BlueGray05}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Brown]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource Brown05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource Brown05}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=DeepOrange]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource DeepOrange05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource DeepOrange05}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=DeepPurple]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource DeepPurple05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource DeepPurple05}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Gray]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource Gray05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource Gray05}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Green]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource Green05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource Green05}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Indigo]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource Indigo05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource Indigo05}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Orange]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource Orange05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource Orange05}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Pink]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource Pink05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource Pink05}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Purple]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource Purple05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource Purple05}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Red]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource Red05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource Red05}" />
			</Style>
		</Style>
		<Style Selector="^[(Theme.Color)=Teal]">
			<Style Selector="^ /template/ Thumb#Thumb:pointerover">
				<Setter Property="Background" Value="{DynamicResource Teal05}" />
			</Style>
			<Style Selector="^[IsExpanded=true] /template/ Thumb#Thumb">
				<Setter Property="Background" Value="{DynamicResource Teal05}" />
			</Style>
		</Style>
		<!-- Generated Code - /Colors -->

	</ControlTheme>

	<Design.PreviewWith>
		<PreviewCodeSnippet Width="700">
			<StackPanel Spacing="10"
					HorizontalAlignment="Center"
					VerticalAlignment="Top">
				<ScrollViewer
						Width="200"
						Height="200"
						HorizontalScrollBarVisibility="Visible"
						VerticalScrollBarVisibility="Visible">

					<Border Width="400"
							Height="400">
						<Border.Background>
							<VisualBrush TileMode="Tile"
									SourceRect="0,0,40,40"
									DestinationRect="0,0,40,40"
									Stretch="None">
								<VisualBrush.Visual>
									<Canvas Width="40" Height="40">
										<Rectangle Canvas.Left="0" Canvas.Top="0" Width="20" Height="20"
												Fill="{StaticResource Red05}" />
										<Rectangle Canvas.Left="20" Canvas.Top="0" Width="20" Height="20"
												Fill="{StaticResource Green05}" />
										<Rectangle Canvas.Left="0" Canvas.Top="20" Width="20" Height="20"
												Fill="{StaticResource Blue06}" />
										<Rectangle Canvas.Left="20" Canvas.Top="20" Width="20" Height="20"
												Fill="{StaticResource Yellow05}" />
									</Canvas>
								</VisualBrush.Visual>
							</VisualBrush>
						</Border.Background>
					</Border>
				</ScrollViewer>
			</StackPanel>
			<PreviewCodeSnippet.ItemTemplate>
				<DataTemplate DataType="ThemeColor">
					<Grid>
						<ScrollBar x:Name="H-Bar"
								Theme.Color="{Binding}"
								Width="100"
								Orientation="Horizontal"
								VerticalAlignment="Bottom" />
						<TextBlock Text="{Binding}"
								HorizontalAlignment="Center"
								VerticalAlignment="Center" />
						<ScrollBar Theme.Color="{Binding}"
								Height="100"
								Orientation="Vertical"
								HorizontalAlignment="Left"
								Margin="0,0,0,16" />
					</Grid>
				</DataTemplate>
			</PreviewCodeSnippet.ItemTemplate>
		</PreviewCodeSnippet>
	</Design.PreviewWith>
</ResourceDictionary>