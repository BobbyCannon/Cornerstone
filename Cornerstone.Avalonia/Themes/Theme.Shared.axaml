<ResourceDictionary xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Design.PreviewWith>
		<Grid RowDefinitions="*,*" >
			<TabControl Grid.Row="0"
					Height="100"
					Margin="0,0,0,20">
				<TabItem Header="Foo Bar"></TabItem>
				<TabItem Header="Hello World"></TabItem>
				<TabItem Header="aoeu"></TabItem>
			</TabControl>
			<DockingTabControl Grid.Row="1"
					Height="100">
				<DockableTabItem Header="foo bar"></DockableTabItem>
				<DockableTabItem Header="hello world"></DockableTabItem>
				<DockableTabItem Header="aoeu"></DockableTabItem>
			</DockingTabControl>
		</Grid>
	</Design.PreviewWith>

	<!-- Global Basics-->
	<SolidColorBrush x:Key="StandardFontForeground" Color="{DynamicResource Foreground00}" />
	<SolidColorBrush x:Key="ControlBorder" Color="{DynamicResource Foreground09}" />

	<Color x:Key="Color.Terminal.Background">#FF012456</Color>
	<SolidColorBrush x:Key="Brush.Terminal.Background" Color="{DynamicResource Color.Terminal.Background}" />
	<Color x:Key="Color.Terminal.Foreground">#FFD8D8D8</Color>
	<SolidColorBrush x:Key="Brush.Terminal.Foreground" Color="{DynamicResource Color.Terminal.Foreground}" />

	<!-- AdornerLayer resources. -->
	<SolidColorBrush x:Key="AdornerPrimaryBrush" Color="{DynamicResource Background00}" />
	<SolidColorBrush x:Key="AdornerSecondaryBrush" Color="{DynamicResource Background00}" Opacity="0.5" />

	<!-- AutoCompleteBox resources. -->
	<SolidColorBrush x:Key="AutoCompleteBoxSuggestionsListBackground" Color="{DynamicResource Background02}" />
	<SolidColorBrush x:Key="AutoCompleteBoxSuggestionsListBorderBrush" Color="{DynamicResource Background05}" />

	<!-- Border resources. -->
	<SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource Foreground09}" />

	<!-- Button resources. -->
	<SolidColorBrush x:Key="ButtonBackground" Color="{DynamicResource Background01}" />
	<SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{DynamicResource Background04}" />
	<SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{DynamicResource Background06}" />
	<SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="{DynamicResource Background03}" />
	<SolidColorBrush x:Key="ButtonForeground" Color="{DynamicResource Foreground00}" />
	<SolidColorBrush x:Key="ButtonForegroundDisabled" Color="{DynamicResource Foreground06}" />
	<SolidColorBrush x:Key="ButtonBorderBrush" Color="{DynamicResource Background05}" />

	<!-- Calendar resources. -->
	<SolidColorBrush x:Key="CalendarViewBackground" Color="{DynamicResource Background02}" />
