<ResourceDictionary xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Design.PreviewWith>
		<StackPanel Spacing="10">
			<TextBlock Classes="Header" Text="x:Static" />
			<TextBlock FontFamily="{x:Static CornerstoneTheme.DejaVuSansMono}"
					FontSize="22"
					Text="DejaVu Sans Mono : 0oO1LlIi The quick brown foxed jumped..."/>
			<TextBlock FontFamily="{x:Static CornerstoneTheme.DejaVuSansLight}"
					FontSize="22"
					Text="DejaVu Sans Light   : 0oO1LlIi The quick brown foxed jumped..."/>
			
			<TextBlock Classes="Header"
					Text="Static Resource"
					Margin="0,20,0,0" />
			<TextBlock FontFamily="{StaticResource DejaVuSansMono}"
					FontSize="22"
					Text="DejaVu Sans Mono : 0oO1LlIi"/>
			<TextBlock FontFamily="{StaticResource DejaVuSansLight}"
					FontSize="22"
					Text="DejaVu Sans Light   : 0oO1LlIi"/>
		</StackPanel>
	</Design.PreviewWith>

	<FontFamily x:Key="DejaVuSansMono">avares://Cornerstone.Avalonia/Assets/Fonts/DejaVuSansMono.ttf#DejaVu Sans Mono</FontFamily>
	<FontFamily x:Key="DejaVuSansLight">avares://Cornerstone.Avalonia/Assets/Fonts/DejaVuSansLight.ttf#DejaVu Sans Light</FontFamily>

</ResourceDictionary>