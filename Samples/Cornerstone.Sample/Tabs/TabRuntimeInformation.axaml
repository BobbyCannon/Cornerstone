<UserControl
		xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:tabs="clr-namespace:Cornerstone.Sample.Tabs"
		mc:Ignorable="d" d:DesignHeight="300" d:DesignWidth="300"
		x:Class="Cornerstone.Sample.Tabs.TabRuntimeInformation"
		x:DataType="tabs:TabRuntimeInformation">
	<DockPanel Margin="10">
		<Grid DockPanel.Dock="Top">
			<TextBlock Classes="HeaderSix"
					HorizontalAlignment="Center"
					Text="Runtime Information" />
		</Grid>
		<ScrollViewer>
			<PropertyGridControl Source="{Binding RuntimeInformation}"/>
		</ScrollViewer>
	</DockPanel>
</UserControl>