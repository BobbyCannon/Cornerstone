<avalonia:CornerstoneApplication xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:avalonia="clr-namespace:Cornerstone.Avalonia;assembly=Cornerstone.Avalonia"
		x:Class="Avalonia.Sample.App">
	<avalonia:CornerstoneApplication.Styles>
		<CornerstoneTheme ThemeColor="Blue" />
		<StyleInclude Source="avares://Cornerstone.Avalonia.DataGrid/Index.axaml" />
		<StyleInclude Source="avares://Cornerstone.Avalonia.ColorPicker/Index.axaml" />
	</avalonia:CornerstoneApplication.Styles>
</avalonia:CornerstoneApplication>