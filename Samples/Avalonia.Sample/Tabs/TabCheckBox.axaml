<UserControl
		xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
		x:Class="Avalonia.Sample.Tabs.TabCheckBox">
	<Grid
			Margin="8"
			VerticalAlignment="Top"
			HorizontalAlignment="Left"
			ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
			RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
		<CheckBox
				Grid.Row="0" Grid.Column="0"
				Content="Theme Checked"
				IsChecked="True"
				Width="200"
				Margin="4" />

		<CheckBox
				Grid.Row="0" Grid.Column="1"
				Content="Theme Indeterminate"
				IsChecked="{x:Null}"
				Width="200"
				Margin="4" />

		<CheckBox
				Grid.Row="0" Grid.Column="2"
				Content="Theme Unchecked"
				Width="200"
				Margin="4" />

		<CheckBox
				Grid.Row="0" Grid.Column="3"
				Content="Theme Checked, Disabled"
				IsChecked="True"
				IsEnabled="False"
				Width="200"
				Margin="4" />

		<CheckBox
				Grid.Row="0" Grid.Column="4"
				Content="Theme Indeterminate, Disabled"
				IsChecked="{x:Null}"
				IsEnabled="False"
				Width="200"
				Margin="4" />

		<CheckBox
				Grid.Row="0" Grid.Column="5"
				Content="Theme Unchecked, Disabled"
				IsEnabled="False"
				Width="200"
				Margin="4" />

		<!-- Red. -->

		<CheckBox
				Grid.Row="1" Grid.Column="0"
				Theme.Color="Red"
				Content="Red Checked"
				IsChecked="True"
				Width="200"
				Margin="4" />

		<CheckBox
				Grid.Row="1" Grid.Column="1"
				Theme.Color="Red"
				Content="Red Indeterminate"
				IsChecked="{x:Null}"
				Width="200"
				Margin="4" />

		<CheckBox
				Grid.Row="1" Grid.Column="2"
				Theme.Color="Red"
				Content="Red Unchecked"
				Width="200"
				Margin="4" />

		<CheckBox
				Grid.Row="1" Grid.Column="3"
				Theme.Color="Red"
				Content="Red Checked, Disabled"
				IsChecked="True"
				IsEnabled="False"
				Width="200"
				Margin="4" />

		<CheckBox
				Grid.Row="1" Grid.Column="4"
				Theme.Color="Red"
				Content="Red Indeterminate, Disabled"
				IsChecked="{x:Null}"
				IsEnabled="False"
				Width="200"
				Margin="4" />

		<CheckBox
				Grid.Row="1" Grid.Column="5"
				Theme.Color="Red"
				Content="Red Unchecked, Disabled"
				IsEnabled="False"
				Width="200"
				Margin="4" />

		<!-- Pink. -->

		<CheckBox
				Grid.Row="2" Grid.Column="0"
