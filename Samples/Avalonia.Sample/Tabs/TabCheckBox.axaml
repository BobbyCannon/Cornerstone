				Margin="4" />

		<CheckBox
				Grid.Row="9" Grid.Column="2"
				Theme.Color="Amber"
				Content="Amber Unchecked"
				Width="200"
				Margin="4" />

		<CheckBox
				Grid.Row="9" Grid.Column="3"
