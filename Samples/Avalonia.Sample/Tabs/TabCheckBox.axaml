				IsEnabled="False"
				Width="200"
				Margin="4" />

		<CheckBox
				Grid.Row="4" Grid.Column="4"
				Theme.Color="DeepPurple"
				Content="Deep Purple Indeterminate, Disabled"
				IsChecked="{x:Null}"
				IsEnabled="False"
				Width="200"
				Margin="4" />

		<CheckBox
				Grid.Row="4" Grid.Column="5"
				Theme.Color="DeepPurple"
				Content="Deep Purple Unchecked, Disabled"
				IsEnabled="False"
				Width="200"
				Margin="4" />

		<!-- Indigo. -->

		<CheckBox
				Grid.Row="5" Grid.Column="0"
