				Content="Brown"
				Width="200"
				Margin="4"
				GroupName="Brown" />

		<RadioButton
				Grid.Row="12" Grid.Column="2"
				Theme.Color="Brown"
				Content="Brown (Disabled)"
				IsChecked="True"
