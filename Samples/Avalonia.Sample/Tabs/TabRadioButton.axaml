				Grid.Row="5" Grid.Column="1"
				Theme.Color="Indigo"
				Content="Indigo"
				Width="200"
				Margin="4"
				GroupName="Indigo" />

		<RadioButton
				Grid.Row="5" Grid.Column="2"
				Theme.Color="Indigo"
