				Content="Red (Disabled)"
				IsChecked="True"
				IsEnabled="False"
				Width="200"
				Margin="4"
				GroupName="RedDisabled" />

		<RadioButton
				Grid.Row="1" Grid.Column="3"
				Theme.Color="Red"
				Content="Red (Disabled)"
				IsEnabled="False"
				Width="200"
				Margin="4"
				GroupName="RedDisabled" />

		<!-- Pink. -->

		<RadioButton
				Grid.Row="2" Grid.Column="0"
				Theme.Color="Pink"
				Content="Pink"
				IsChecked="True"
				Width="200"
				Margin="4"
				GroupName="Pink" />

		<RadioButton
				Grid.Row="2" Grid.Column="1"
