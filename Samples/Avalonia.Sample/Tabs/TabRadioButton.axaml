		<RadioButton
				Grid.Row="11" Grid.Column="1"
				Theme.Color="DeepOrange"
				Content="Deep Orange"
				Width="200"
				Margin="4"
				GroupName="DeepOrange" />

		<RadioButton
				Grid.Row="11" Grid.Column="2"
