<UserControl
		xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
		x:Class="Avalonia.Sample.Tabs.TabTextEditor">
	<DockPanel LastChildFill="True">
		<ThemeVariantScope DockPanel.Dock="Top"
				RequestedThemeVariant="Light">
			<StackPanel Margin="10">
				<Button>should be light theme</Button>
			</StackPanel>
		</ThemeVariantScope>
		<UniformGrid Columns="2">
			<TextEditorControl x:Name="CSharp" />
			<TextEditorControl x:Name="Html" />
			<TextEditorControl x:Name="Json" />
			<TextEditorControl x:Name="PowerShell" />
			<TextEditorControl x:Name="Xml" />
		</UniformGrid>
	</DockPanel>
</UserControl>