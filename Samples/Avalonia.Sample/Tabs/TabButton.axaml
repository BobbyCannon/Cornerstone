					Theme.Color="Amber"
					Content="{Binding #AmberToggleButton.Content}"
					IsChecked="{Binding #AmberToggleButton.IsChecked}"
					IsEnabled="False"
					IsThreeState="True" />

			<DropDownButton
					Grid.Row="10" Grid.Column="4"
					Theme.Color="Amber"
					Content="Amber"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<DropDownButton
					Grid.Row="10" Grid.Column="5"
					Theme.Color="Amber"
					Content="Amber (Disabled)"
