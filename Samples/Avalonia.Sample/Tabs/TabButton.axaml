					Content="{Binding #DeepPurpleToggleButton.Content}"
					IsChecked="{Binding #DeepPurpleToggleButton.IsChecked}"
					IsEnabled="False"
					IsThreeState="True" />

			<DropDownButton
					Grid.Row="5" Grid.Column="4"
					Theme.Color="DeepPurple"
					Content="DeepPurple"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<DropDownButton
					Grid.Row="5" Grid.Column="5"
					Theme.Color="DeepPurple"
					Content="DeepPurple (Disabled)"
					IsEnabled="False"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<SplitButton
					Grid.Row="5" Grid.Column="6"
					Theme.Color="DeepPurple"
					Content="DeepPurple"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<SplitButton
					Grid.Row="5" Grid.Column="7"
					Theme.Color="DeepPurple"
					Content="DeepPurple (Disabled)"
					IsEnabled="False"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<ToggleSplitButton
					Grid.Row="5" Grid.Column="8"
					Theme.Color="DeepPurple"
					x:Name="DeepPurpleToggleSplitButton"
					Content="Checked"
					IsChecked="True"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<ToggleSplitButton
					Grid.Row="5" Grid.Column="9"
					Theme.Color="DeepPurple"
					Content="{Binding #DeepPurpleToggleSplitButton.Content}"
					IsChecked="{Binding #DeepPurpleToggleSplitButton.IsChecked}"
					IsEnabled="False"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<!-- Indigo button. -->

			<Button
					Grid.Row="6" Grid.Column="0"
					Theme.Color="Indigo"
					Content="Indigo" />

			<Button
					Grid.Row="6" Grid.Column="1"
					Theme.Color="Indigo"
					Content="Indigo (Disabled)"
					IsEnabled="False" />

			<ToggleButton
					Grid.Row="6" Grid.Column="2"
					Theme.Color="Indigo"
					x:Name="IndigoToggleButton"
					Classes="ToggleText"
					IsChecked="True"
					IsThreeState="True" />

			<ToggleButton
					Grid.Row="6" Grid.Column="3"
					Theme.Color="Indigo"
					Content="{Binding #IndigoToggleButton.Content}"
					IsChecked="{Binding #IndigoToggleButton.IsChecked}"
					IsEnabled="False"
					IsThreeState="True" />

			<DropDownButton
					Grid.Row="6" Grid.Column="4"
					Theme.Color="Indigo"
					Content="Indigo"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<DropDownButton
					Grid.Row="6" Grid.Column="5"
					Theme.Color="Indigo"
					Content="Indigo (Disabled)"
					IsEnabled="False"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<SplitButton
					Grid.Row="6" Grid.Column="6"
					Theme.Color="Indigo"
					Content="Indigo"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<SplitButton
					Grid.Row="6" Grid.Column="7"
					Theme.Color="Indigo"
					Content="Indigo (Disabled)"
					IsEnabled="False"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<ToggleSplitButton
					Grid.Row="6" Grid.Column="8"
					Theme.Color="Indigo"
					x:Name="IndigoToggleSplitButton"
					Content="Checked"
					IsChecked="True"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<ToggleSplitButton
					Grid.Row="6" Grid.Column="9"
					Theme.Color="Indigo"
					Content="{Binding #IndigoToggleSplitButton.Content}"
					IsChecked="{Binding #IndigoToggleSplitButton.IsChecked}"
					IsEnabled="False"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<!-- Blue button. -->

			<Button
					Grid.Row="7" Grid.Column="0"
					Theme.Color="Blue"
					Content="Blue" />

			<Button
					Grid.Row="7" Grid.Column="1"
					Theme.Color="Blue"
					Content="Blue (Disabled)"
					IsEnabled="False" />

			<ToggleButton
					Grid.Row="7" Grid.Column="2"
					Theme.Color="Blue"
					x:Name="BlueToggleButton"
					Classes="ToggleText"
					IsChecked="True"
					IsThreeState="True" />

			<ToggleButton
