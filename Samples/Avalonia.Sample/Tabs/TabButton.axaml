					Flyout="{StaticResource SharedMenuFlyout}" />

			<ToggleSplitButton
					Grid.Row="7" Grid.Column="9"
					Theme.Color="Blue"
					Content="{Binding #BlueToggleSplitButton.Content}"
					IsChecked="{Binding #BlueToggleSplitButton.IsChecked}"
					IsEnabled="False"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<!-- Teal button. -->

			<Button
					Grid.Row="8" Grid.Column="0"
					Theme.Color="Teal"
