					Theme.Color="Teal"
					Content="Teal"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<SplitButton
					Grid.Row="8" Grid.Column="7"
					Theme.Color="Teal"
					Content="Teal (Disabled)"
					IsEnabled="False"
					Flyout="{StaticResource SharedMenuFlyout}" />

			<ToggleSplitButton
