<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
		xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
		xmlns:maui="clr-namespace:Sample.Client.Maui"
		xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
		x:Class="Sample.Client.Maui.Pages.SpeedyListPage"
		x:DataType="maui:MauiViewManager">
	<ContentPage.Content>
		<toolkit:DockLayout ShouldExpandLastChild="True">
			<HorizontalStackLayout
					toolkit:DockLayout.DockPosition="Top"
					HorizontalOptions="Center"
					VerticalOptions="Start">
				<Image WidthRequest="32" 
						HeightRequest="32"
						HorizontalOptions="Center"
						Margin="10">
					<Image.Source>
						<x:FontImage FontFamily="FontAwesome"
								Size="256"
								Glyph="&#xf0ae;"
								Color="White" />
					</Image.Source>
				</Image>
				<Label Text="Speedy List"
						FontSize="28"
						FontFamily="OpenSans-Light"
						Margin="0,6,0,0" />
			</HorizontalStackLayout>
			<StackLayout toolkit:DockLayout.DockPosition="Bottom">
				<Button Text="test" />
			</StackLayout>
			<StackLayout>
				<Label Text="Test"
						HorizontalOptions="Center" />
			</StackLayout>
		</toolkit:DockLayout>
	</ContentPage.Content>
</ContentPage>